# ======================================================================
# GEICO Insurance Agent — environment template
# Copy this file to `.env` and fill in the values marked <...>. The real
# `.env` is gitignored; only this template is committed.
# ======================================================================

# ---------------------------------------------------------------------
# LLM-Shield (Votal Shield)
# ---------------------------------------------------------------------
# Base URL of your Shield deployment. Use the RunPod gateway URL if
# Shield is hosted on RunPod, or http://localhost:8000 for a local dev
# build. Do NOT include a trailing slash.
LLM_SHIELD_URL=<https://your-shield-host>

# Admin key for Shield (shown in Shield's admin portal under
# "Platform → Admin keys"). Required by setup_tenant.py to provision
# the tenant and push policies. Not used at runtime.
SHIELD_ADMIN_KEY=<your-shield-admin-key>

# If your Shield is behind the RunPod API gateway, set the RunPod
# bearer token here. Leave blank for self-hosted / local Shield.
RUNPOD_TOKEN=

# ---------------------------------------------------------------------
# Tenant
# ---------------------------------------------------------------------
# Tenant identifier this app runs under. `setup_tenant.py` will create
# it if it does not already exist. Do not change unless you know what
# you're doing — several scripts hard-code "geico-poc".
TENANT_ID=geico-poc

# Leave blank on first run. `setup_tenant.py` will provision the tenant,
# create an API key, and write it back into your .env automatically.
TENANT_API_KEY=

# ---------------------------------------------------------------------
# LLM provider (OpenAI)
# ---------------------------------------------------------------------
OPENAI_API_KEY=<your-openai-key>
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------
PORT=7860
